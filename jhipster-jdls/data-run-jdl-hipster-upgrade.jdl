entity Activity {
    uid String unique maxlength(11)
    code String unique
    name String
    startDate Instant
    endDate Instant
    disabled Boolean
    deleteClientData Boolean
}

entity Assignment {
    uid String required unique maxlength(11)
    code String unique
    disabled Boolean
}

entity OuLevel {
    uid String unique maxlength(11)
    name String
    code String
    level Integer required
}

relationship ManyToOne {
    Assignment {activity (code)} to Activity{assignment}
}
