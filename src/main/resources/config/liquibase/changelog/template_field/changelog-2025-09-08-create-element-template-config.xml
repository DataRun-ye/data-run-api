<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="2025-09-08-create-element-template-config" author="assistant">
        <!-- Sequence for id generation (used by JPA SequenceGenerator) -->
        <createSequence sequenceName="element_template_config_seq" startValue="1" incrementBy="1"/>

        <!-- Main table creation -->
        <createTable tableName="element_template_config">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false" />
            </column>

            <column name="uid" type="varchar(11)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="template_uid" type="varchar(11)">
                <constraints nullable="false"/>
            </column>

            <column name="template_version_uid" type="varchar(11)">
                <constraints nullable="false"/>
            </column>

            <column name="template_version_no" type="integer">
                <constraints nullable="false"/>
            </column>

            <column name="data_element_uid" type="varchar(11)">
                <constraints nullable="false"/>
            </column>

            <column name="id_path" type="text">
                <constraints nullable="false"/>
            </column>

            <column name="sort_order" type="integer"/>

            <column name="name_path" type="text"/>

            <column name="semantic_path" type="text"/>

            <column name="has_repeatable_ancestor" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="repeat_ancestor_path" type="text"/>

            <column name="semantic_repeat_ancestor_path" type="text"/>

            <column name="is_multi" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="is_measure" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>

            <column name="is_dimension" type="boolean" defaultValueBoolean="false"/>

            <column name="aggregation_type" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="display_label" type="jsonb"/>

            <column name="definition_json" type="jsonb"/>

            <column name="element_kind" type="varchar(16)" defaultValue="FIELD">
                <constraints nullable="false"/>
            </column>

            <!-- Copied metadata from canonical data element / option set -->
            <column name="value_type" type="varchar(64)"/>
            <column name="option_set_uid" type="varchar(11)"/>

            <!-- Path hash for fast lookup (computed by generator) -->
            <column name="path_hash" type="bigint"/>

            <!-- Reference / canonical join hints -->
            <column name="is_reference" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="reference_type" type="varchar(32)"/>

            <!-- Sensitivity -->
            <column name="is_sensitive" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="sensitivity_level" type="varchar(16)"/>

            <!-- Repeat instance identity & ordering -->
            <column name="repeat_id_field" type="varchar(64)"/>
            <column name="repeat_index_field" type="varchar(64)"/>
            <column name="repeat_generate_strategy" type="varchar(32)"/>

            <!-- Semantic grain for analytics: 'submission' or 'repeat:<repeat_path>' -->
            <column name="semantic_grain" type="varchar(255)"/>

            <!-- Visibility / required expressions and dependency keys -->
            <column name="visibility_expression" type="text"/>
            <column name="visibility_dependency_keys" type="jsonb"/>

            <column name="required_expression" type="text"/>
            <column name="rule_dependency_keys" type="jsonb"/>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="now()"/>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="now()"/>
            <column name="created_by" type="varchar(64)"/>
            <column name="updated_by" type="varchar(64)"/>
        </createTable>

        <!-- Constraints and indexes -->
        <addUniqueConstraint tableName="element_template_config"
                             columnNames="template_version_uid,id_path"
                             constraintName="ux_element_template_config_template_version_id_path"/>

        <createIndex tableName="element_template_config"
                     indexName="idx_element_template_config_template_version_pathhash">
            <column name="template_version_uid"/>
            <column name="path_hash"/>
        </createIndex>

        <createIndex tableName="element_template_config"
                     indexName="idx_element_template_config_template_uid_de_uid">
            <column name="template_uid"/>
            <column name="data_element_uid"/>
        </createIndex>

<!--        &lt;!&ndash; Optional GIN indexes for jsonb fields you may query &ndash;&gt;-->
<!--        <createIndex tableName="element_template_config"-->
<!--                     indexName="gin_idx_element_template_config_display_label"-->
<!--                     indexType="GIN">-->
<!--            <column name="display_label"/>-->
<!--        </createIndex>-->

<!--        <createIndex tableName="element_template_config"-->
<!--                     indexName="gin_idx_element_template_config_def_json"-->
<!--                     indexType="GIN">-->
<!--            <column name="definition_json"/>-->
<!--        </createIndex>-->

        <!-- Rollback: drop table and sequence -->
        <rollback>
            <dropTable tableName="element_template_config"/>
            <dropSequence sequenceName="element_template_config_seq"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
