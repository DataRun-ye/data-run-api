<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1755970544218-4"
               author="Hamza">
        <createSequence incrementBy="1"
                        sequenceName="element_template_config_seq"
                        startValue="1"/>
    </changeSet>
    <changeSet id="1755970544218-7"
               author="Hamza">
        <createTable tableName="element_template_config">
            <column name="id"
                    type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_element_template_config"/>
            </column>
            <column name="template_id"
                    type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="template_version_id"
                    type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="version_no"
                    type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="data_element_id"
                    type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="template_order"
                    type="integer"/>
            <column name="id_path"
                    type="text">
                <constraints nullable="false"/>
            </column>
            <column name="name_path"
                    type="text"/>
            <column name="name"
                    type="text">
                <constraints nullable="false"/>
            </column>
            <column name="value_type"
                    type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="aggregation_type"
                    type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="is_reference"
                    type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="reference_table"
                    type="VARCHAR(100)"/>
            <column name="option_set_id"
                    type="VARCHAR(100)"/>
            <column name="is_repeatable"
                    type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="repeat_path"
                    type="text"/>
            <column name="is_multi"
                    type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="is_category"
                    type="BOOLEAN"/>
            <column name="is_measure"
                    type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="category_for_repeat"
                    type="VARCHAR(26)"/>
            <column name="display_label"
                    type="jsonb"/>
            <column name="definition_json"
                    type="jsonb"/>
            <column name="element_kind"
                    type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at"
                    type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1755970544218-12"
               author="Hamza">
        <addUniqueConstraint columnNames="template_id, template_version_id, id_path"
                             constraintName="ux_element_template_config_tpl_ver_idpath"
                             tableName="element_template_config"/>
    </changeSet>
    <changeSet id="1755970544218-16"
               author="Hamza">
        <createIndex indexName="idx_element_template_config_dataelement"
                     tableName="element_template_config">
            <column name="data_element_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="1755970544218-17"
               author="Hamza">
        <createIndex indexName="idx_element_template_config_repeat_path"
                     tableName="element_template_config">
            <column name="template_id"/>
            <column name="repeat_path"/>
        </createIndex>
    </changeSet>
    <changeSet id="1755970544218-18"
               author="Hamza">
        <createIndex indexName="idx_element_template_config_template_version"
                     tableName="element_template_config">
            <column name="template_id"/>
            <column name="template_version_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="1755970544218-19"
               author="Hamza">
        <createIndex indexName="idx_element_template_config_template_version_no"
                     tableName="element_template_config">
            <column name="template_id"/>
            <column name="version_no"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
