<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1757388734054-36" author="Hamza">
        <createTable tableName="element_template_config">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_element_template_config"/>
            </column>
            <column name="uid" type="VARCHAR(11)">
                <constraints nullable="false"/>
            </column>
            <column name="element_kind" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="template_uid" type="VARCHAR(11)">
                <constraints nullable="false"/>
            </column>
            <column name="template_version_uid" type="VARCHAR(11)">
                <constraints nullable="false"/>
            </column>
            <column name="template_version_no" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="data_element_uid" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="value_type" type="VARCHAR(255)"/>
            <column name="aggregation_type" type="VARCHAR(32)"/>
            <column name="is_reference" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="category_id" type="VARCHAR(26)"/>
            <column name="is_category" type="BOOLEAN"/>
            <column name="option_set_uid" type="VARCHAR(11)"/>
            <column name="is_multi" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="is_measure" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="is_dimension" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="sort_order" type="INT"/>
            <column name="semantic_grain" type="VARCHAR(255)"/>
            <column name="id_path" type="VARCHAR(3000)">
                <constraints nullable="false"/>
            </column>
            <column name="path_hash" type="BIGINT"/>
            <column name="name_path" type="VARCHAR(3000)"/>
            <column name="semantic_path" type="VARCHAR(3000)"/>
            <column name="has_repeat_ancestor" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="ancestor_repeat_semantic_path" type="VARCHAR(3000)"/>
            <column name="ancestor_repeat_path" type="VARCHAR(3000)"/>
            <column name="display_label" type="jsonb"/>
            <column name="definition_json" type="jsonb"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1757388734054-37" author="Hamza">
        <addUniqueConstraint columnNames="uid" constraintName="uc_element_template_config_uid"
                             tableName="element_template_config"/>
    </changeSet>
    <changeSet id="1757388734054-38" author="Hamza">
        <addUniqueConstraint columnNames="template_uid, template_version_uid, id_path"
                             constraintName="ux_element_template_config_tpl_ver_idpath"
                             tableName="element_template_config"/>
    </changeSet>
    <changeSet id="1757388734054-39" author="Hamza">
        <createIndex indexName="idx_element_template_config_dataelement" tableName="element_template_config">
            <column name="data_element_uid"/>
        </createIndex>
    </changeSet>
    <changeSet id="1757388734054-40" author="Hamza">
        <createIndex indexName="idx_element_template_config_repeat_path" tableName="element_template_config">
            <column name="template_uid"/>
            <column name="ancestor_repeat_path"/>
        </createIndex>
    </changeSet>
    <changeSet id="1757388734054-41" author="Hamza">
        <createIndex indexName="idx_element_template_config_template_version" tableName="element_template_config">
            <column name="template_uid"/>
            <column name="template_version_uid"/>
        </createIndex>
    </changeSet>
    <changeSet id="1757388734054-42" author="Hamza">
        <createIndex indexName="idx_element_template_config_template_version_no" tableName="element_template_config">
            <column name="template_uid"/>
            <column name="template_version_no"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
