<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet author="hamza-ye" id="001-add-user_last_seen-table">
        <createTable tableName="user_last_seen">
            <column name="user_id" type="varchar(26)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_user_last_seen"/>
            </column>
            <column name="last_seen" type="timestamp"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
