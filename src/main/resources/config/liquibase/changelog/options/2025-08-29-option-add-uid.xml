<!--            &lt;!&ndash; ensure no duplicates before adding constraints &ndash;&gt;-->
<!--            <sqlCheck expectedResult="0">-->
<!--                SELECT count(*) FROM (-->
<!--                SELECT uid FROM option_value GROUP BY uid HAVING count(*) > 1) t;-->
<!--            </sqlCheck>-->
<!--        </preConditions>-->
<!--        &lt;!&ndash; no-op SQL so preCondition runs &ndash;&gt;-->
<!--        <sql>SELECT 1</sql>-->
<!--    </changeSet>-->

    <!-- 4) Make NOT NULL -->
    <changeSet id="make-uid-not-null" author="Hamza">
        <addNotNullConstraint tableName="option_value" columnName="uid" columnDataType="VARCHAR(11)"/>
    </changeSet>

    <!-- 5) Add unique constraint -->
    <changeSet id="uc-option-value-uid" author="Hamza">
        <addUniqueConstraint columnNames="uid" constraintName="uc_option_value_uid" tableName="option_value"/>
    </changeSet>

</databaseChangeLog>
