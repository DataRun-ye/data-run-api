<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.19.xsd">

    <!-- Enable pg_trgm extension for GIN indexes (if not already enabled) -->
    <changeSet id="enable_flow_instance_pg_trgm" author="Hamza">
        <sql>
            CREATE EXTENSION IF NOT EXISTS pg_trgm;
        </sql>
    </changeSet>

    <!-- Index for ancestor queries (GIN with gin_trgm_ops) -->
    <changeSet id="create_flow_instance_gin_path_index" author="Hamza">
        <!-- For ancestor queries (array operations) -->
        <sql>
            CREATE INDEX IF NOT EXISTS idx_flow_instance_path_gin
                ON flowInstance USING GIN (path gin_trgm_ops);
        </sql>
    </changeSet>

    <!-- Index for descendant queries (varchar_pattern_ops) -->
    <changeSet id="create_flow_instance_varchar_pattern_index" author="Hamza">
        <!-- For descendant queries (path prefix matching) -->
        <sql>
            CREATE INDEX IF NOT EXISTS idx_flow_instance_path_prefix
                ON flowInstance (path varchar_pattern_ops);
        </sql>
    </changeSet>

</databaseChangeLog>
