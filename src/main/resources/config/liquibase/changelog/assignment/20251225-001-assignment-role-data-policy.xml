<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <!-- Assignment -> vocabulary   -->
    <changeSet id="create-assignment_role_data_policy" author="hamza-ye">
        <createTable tableName="assignment_role_data_policy">
            <column name="id" type="VARCHAR(26)">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_assignment_role_data_policy"/>
            </column>
            <column name="uid" type="VARCHAR(11)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(32)">
                <constraints unique="true"/>
            </column>
            <column name="name" type="VARCHAR(50)">
            </column>
            <column name="assignment_id" type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="data_template_id" type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="access_level" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_date" type="TIMESTAMP">
            </column>
            <column name="last_modified_by" type="VARCHAR(50)">
            </column>
        </createTable>
    </changeSet>

    <!--    -->
    <changeSet id="create-assignment_role_data_policy-constraints" author="hamza-ye">
        <addForeignKeyConstraint baseTableName="assignment_role_data_policy" baseColumnNames="assignment_id"
                                 constraintName="fk_ardp_assignment_id"
                                 referencedTableName="assignment" referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="assignment_role_data_policy" baseColumnNames="data_template_id"
                                 constraintName="fk_ardp_data_template_id"
                                 referencedTableName="data_template" referencedColumnNames="id"/>

        <addUniqueConstraint tableName="assignment_role_data_policy" columnNames="assignment_id, role, data_template_id"
                             constraintName="ux_assign_role_data_policy_ids"/>

        <createIndex tableName="assignment_role_data_policy" indexName="idx_ardp_assignment_role">
            <column name="assignment_id"/>
            <column name="role"/>
            <column name="data_template_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
