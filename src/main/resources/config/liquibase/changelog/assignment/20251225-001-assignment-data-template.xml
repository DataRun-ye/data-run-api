<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <!-- Assignment -> vocabulary   -->
    <changeSet id="create-assignment_data_template" author="hamza-ye">
        <createTable tableName="assignment_data_template">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_assignment_data_template"/>
            </column>
            <column name="assignment_id" type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="data_template_id" type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="principal_type" type="varchar(64)"/> <!-- 'TEAM'|'USER_GROUP'|PARTY_TYPE -->
            <column name="principal_id" type="varchar(26)"/>
            <column name="principal_role" type="VARCHAR(255)"/>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!--    -->
    <changeSet id="create-assignment_data_template-constraints" author="hamza-ye">
        <addForeignKeyConstraint baseTableName="assignment_data_template" baseColumnNames="assignment_id"
                                 constraintName="fk_assignment_data_template_assignment_id"
                                 referencedTableName="assignment" referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="assignment_data_template" baseColumnNames="data_template_id"
                                 constraintName="fk_assignment_data_template_id"
                                 referencedTableName="data_template" referencedColumnNames="id"/>

        <addUniqueConstraint tableName="assignment_data_template" columnNames="assignment_id, data_template_id, principal_id"
                             constraintName="ux_assignment_data_template_ids"/>

        <createIndex tableName="assignment_data_template" indexName="idx_apb_assignment_data_template_role">
            <column name="assignment_id"/>
            <column name="data_template_id"/>
        </createIndex>
        <createIndex tableName="assignment_data_template" indexName="idx_apb_vocabulary_principal">
            <column name="assignment_id"/>
            <column name="principal_type"/>
            <column name="principal_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
