<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity ChvSupply.
    -->
    <changeSet id="20240726221133-1" author="jhipster">
        <createTable tableName="chv_supply">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uid" type="varchar(11)">
                <constraints nullable="false" unique="true" uniqueConstraintName="ux_chv_supply__uid" />
            </column>
            <column name="code" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="item" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="previous_balance" type="integer">
                <constraints nullable="true" />
            </column>
            <column name="new_supply" type="integer">
                <constraints nullable="true" />
            </column>
            <column name="consumed" type="integer">
                <constraints nullable="true" />
            </column>
            <column name="lost_corrupt" type="integer">
                <constraints nullable="true" />
            </column>
            <column name="remaining" type="integer">
                <constraints nullable="true" />
            </column>
            <column name="comment" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="deleted" type="boolean">
                <constraints nullable="true" />
            </column>
            <column name="start_entry_time" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="finished_entry_time" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="status" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="activity_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <column name="team_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="chv_supply" columnName="start_entry_time" columnDataType="${datetimeType}"/>
        <dropDefaultValue tableName="chv_supply" columnName="finished_entry_time" columnDataType="${datetimeType}"/>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->
</databaseChangeLog>
