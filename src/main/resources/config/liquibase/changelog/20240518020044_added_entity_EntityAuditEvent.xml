<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

<!--
        Added the entity EntityAuditEvent.
    -->
    <changeSet id="1749225850985-4" author="Hamza">
        <createTable tableName="app_entity_audit_event">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_app_entity_audit_event"/>
            </column>
            <column name="entity_id" type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(2500)">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_value" type="VARCHAR(50000)"/>
            <column name="commit_version" type="INT"/>
            <column name="modified_by" type="VARCHAR(100)"/>
            <column name="modified_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex indexName="idx_entity_audit_event_entity_type"
                     tableName="app_entity_audit_event">
            <column name="entity_type" type="varchar(2500)"/>
        </createIndex>
        <!-- TODO add an archival job for the table -->
    </changeSet>
</databaseChangeLog>
