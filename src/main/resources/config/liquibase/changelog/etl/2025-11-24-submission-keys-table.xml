<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">


    <changeSet id="20251124-02-create-submission-keys" author="hamza-ye">
        <createTable schemaName="analytics"  tableName="submission_keys">
            <column name="submission_uid" type="varchar(11)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="submission_id" type="varchar(26)"/>
            <column name="assignment_uid" type="varchar(11)"/>
            <column name="submission_serial" type="bigint"/>
            <column name="status" type="varchar(64)"/>
            <column name="activity_uid" type="varchar(11)"/>
            <column name="org_unit_uid" type="varchar(11)"/>
            <column name="team_uid" type="varchar(11)"/>
            <column name="template_uid" type="varchar(11)"/>
            <column name="last_seen" type="timestamp"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>

        <createIndex schemaName="analytics" tableName="submission_keys" indexName="idx_subkeys_activity">
            <column name="activity_uid"/>
        </createIndex>

        <createIndex schemaName="analytics" tableName="submission_keys" indexName="idx_subkeys_org_unit">
            <column name="org_unit_uid"/>
        </createIndex>

        <createIndex schemaName="analytics" tableName="submission_keys" indexName="idx_subkeys_team">
            <column name="team_uid"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
