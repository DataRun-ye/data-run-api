<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">


    <changeSet id="20251124-01-create-canonical_element_anchor" author="hamza-ye">
        <createTable tableName="canonical_element_anchor">
            <column name="canonical_element_id" type="VARCHAR(64)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="anchor_allowed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="anchor_priority" type="integer" defaultValueNumeric="100">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="varchar(255)"/>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="20251124-03-canonical_element_anchor_idx" author="hamza-ye">
        <createIndex tableName="canonical_element_anchor" indexName="idx_anchor_ref_anchor_allowed_priority">
            <column name="anchor_allowed"/>
            <column name="anchor_priority"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
