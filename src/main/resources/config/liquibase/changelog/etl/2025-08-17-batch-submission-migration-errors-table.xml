<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="20250820-01-create-migration-errors" author="hamza">
        <createTable tableName="migration_errors">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- original source id (mongo _id or other identifier) -->
            <column name="source_id" type="varchar(100)"/>

            <!-- optional submission uid discovered in doc -->
            <column name="submission_uid" type="varchar(26)"/>

            <!-- stage where error occurred: READ | PROCESS | WRITE -->
            <column name="stage" type="varchar(16)">
                <constraints nullable="false"/>
            </column>

            <!-- short error summary -->
            <column name="error_class" type="varchar(255)"/>
            <column name="error_message" type="varchar(4000)"/>

            <!-- payload snapshot (jsonb) -->
            <column name="payload" type="jsonb"/>

            <column name="created_at" type="DATETIME" defaultValueComputed="now()"/>
        </createTable>

        <createIndex indexName="idx_migration_errors_source" tableName="migration_errors">
            <column name="source_id"/>
        </createIndex>

        <createIndex indexName="idx_migration_errors_submission" tableName="migration_errors">
            <column name="submission_uid"/>
        </createIndex>

        <createIndex indexName="idx_migration_errors_stage" tableName="migration_errors">
            <column name="stage"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
