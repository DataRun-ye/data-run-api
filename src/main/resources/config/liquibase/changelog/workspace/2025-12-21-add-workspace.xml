    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <!-- ============================================================
       0001 - Create workspace and workspace_user tables
       ============================================================ -->
    <changeSet id="0001-create-workspace-tables" author="hamza-ye">
        <comment>Create workspace primitives for tenancy</comment>

        <createTable tableName="workspace">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="owner_user_id" type="uuid"/>
            <column name="tier" type="text" defaultValue="free"/>
            <column name="created_at" type="timestamp" defaultValueComputed="now()"/>
        </createTable>

        <createTable tableName="workspace_user">
            <column name="workspace_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="varchar(26)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="text" defaultValue="member"/>
            <column name="joined_at" type="timestamp" defaultValueComputed="now()"/>
        </createTable>

        <!-- index & PK for workspace_user -->
        <addPrimaryKey tableName="workspace_user" columnNames="workspace_id, user_id" constraintName="pk_workspace_user"/>
        <createIndex tableName="workspace_user" indexName="idx_workspace_user_user">
            <column name="user_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="workspace_user"/>
            <dropTable tableName="workspace"/>
        </rollback>
    </changeSet>

    <!-- ============================================================
         0002 - Create a default workspace row and backfill workspace_user
         ============================================================ -->
    <changeSet id="0002-insert-default-workspace-and-members" author="hamza-ye" runOnChange="false">
        <comment>Insert a default workspace for the existing single-organization deployment, and add membership rows for all existing users (app_user).</comment>

        <!-- Insert a workspace row. We'll use gen_random_uuid() if extension available; otherwise replace with static uuid -->
        <sql>
            -- Create extension if not present (harmless if present)
            CREATE EXTENSION IF NOT EXISTS "pgcrypto";
        </sql>

        <sql>
            -- Insert a default workspace. Replace name or owner_user_id if you want specific values.
            INSERT INTO workspace (id, name, owner_user_id)
            VALUES ('dddddddd-dddd-dddd-dddd-dddddddddddd'::uuid, 'default_org', NULL);
        </sql>

        <sql>
            -- Backfill membership: add every existing app_user as member of default workspace.
            -- This assumes your users live in table `app_user` with column `id`.
            -- If you prefer to add only specific users, change the WHERE clause.
            INSERT INTO workspace_user (workspace_id, user_id, role)
            SELECT w.id, au.id, 'member'
            FROM workspace w
                     CROSS JOIN app_user au
            WHERE w.name = 'default_org'
              AND NOT EXISTS (
                SELECT 1 FROM workspace_user wu WHERE wu.workspace_id = w.id AND wu.user_id = au.id
            );
        </sql>

        <rollback>
            <sql>DELETE FROM workspace_user WHERE workspace_id IN (SELECT id FROM workspace WHERE name='default_org');</sql>
            <sql>DELETE FROM workspace WHERE name='default_org';</sql>
        </rollback>
    </changeSet>

