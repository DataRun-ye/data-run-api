<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet author="hamza-ye" id="001-add-error-event-table">
        <createTable tableName="error_event">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false"
                             primaryKey="true"
                             primaryKeyName="pk_error_event"/>
            </column>
            <column name="occurred_at" type="DATETIME"/>
            <column name="level" type="VARCHAR(255)"/>
            <column name="status" type="INTEGER"/>
            <column name="path" type="VARCHAR(255)"/>
            <column name="method" type="VARCHAR(255)"/>
            <column name="username" type="VARCHAR(255)"/>
            <column name="client_ip" type="VARCHAR(255)"/>
            <column name="message" type="text"/>
            <column name="exception" type="VARCHAR(255)"/>
            <column name="stacktrace" type="text"/>
            <column name="context_json" type="text"/>
        </createTable>
    </changeSet>


</databaseChangeLog>
