<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <!-- 0001_create_analytics_metadata.xml -->
    <!-- create schema -->
    <changeSet author="hamza" id="create_analytics_schema">
        <sql dbms="postgresql">
            CREATE SCHEMA IF NOT EXISTS analytics;
        </sql>
    </changeSet>
    <changeSet id="analytics-metadata-0001" author="datarun-analyst">
        <!-- analytics_entity -->
        <createTable schemaName="analytics" tableName="analytics_entity">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="data_template_uid" type="varchar(11)">
                <constraints nullable="false"/>
            </column>
            <column name="latest_processed_version_uid" type="varchar(11)"/>
            <column name="uid" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="display_name" type="varchar(255)"/>
            <column name="description" type="text"/>
            <column name="underlying_view_name" type="varchar(255)"/>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_at" type="timestamp"/>
        </createTable>

        <!-- FK: analytics_entity.data_template_uid -> public.data_template(uid) -->
        <addForeignKeyConstraint baseTableSchemaName="analytics"
                                 baseTableName="analytics_entity"
                                 baseColumnNames="data_template_uid"
                                 referencedTableSchemaName="public"
                                 referencedTableName="data_template"
                                 referencedColumnNames="uid"
                                 constraintName="fk_analytics_entity_template"/>
        <createIndex schemaName="analytics" tableName="analytics_entity" indexName="idx_analytics_entity_template_uid">
            <column name="data_template_uid"/>
        </createIndex>
    </changeSet>

    <changeSet id="analytics-metadata-0002" author="datarun-analyst">
        <!-- analytics_attribute -->
        <createTable schemaName="analytics" tableName="analytics_attribute">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entity_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="uid" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="display_name" type="varchar(255)"/>
            <column name="underlying_column_name" type="varchar(255)"/>
            <column name="data_type" type="varchar(50)"/>
            <column name="is_dimension" type="boolean" defaultValueBoolean="true"/>
            <column name="is_measure" type="boolean" defaultValueBoolean="false"/>
            <column name="aggregation_types" type="jsonb"/>
            <column name="is_deprecated" type="boolean" defaultValueBoolean="false"/>
            <column name="reference_info" type="jsonb"/>
            <column name="meta" type="jsonb"/>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_at" type="timestamp"/>
        </createTable>

        <addForeignKeyConstraint baseTableSchemaName="analytics"
                                 baseTableName="analytics_attribute"
                                 baseColumnNames="entity_id"
                                 referencedTableSchemaName="analytics"
                                 referencedTableName="analytics_entity"
                                 referencedColumnNames="id"
                                 constraintName="fk_attribute_entity"/>

        <createIndex schemaName="analytics" tableName="analytics_attribute" indexName="idx_attribute_entity_uid">
            <column name="entity_id"/>
            <column name="uid"/>
        </createIndex>

        <!-- Optional unique constraint per-entity on uid -->
        <addUniqueConstraint schemaName="analytics" tableName="analytics_attribute" columnNames="entity_id, uid"
                             constraintName="ux_attr_entity_uid"/>
    </changeSet>

    <changeSet id="analytics-metadata-0003" author="datarun-analyst">
        <!-- analytics_relationship -->
        <createTable schemaName="analytics" tableName="analytics_relationship">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="from_entity_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="to_entity_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="join_from_attribute_uid" type="varchar(255)"/>
            <column name="join_to_attribute_uid" type="varchar(255)"/>
            <column name="join_type" type="varchar(50)" defaultValue="LEFT"/>
            <column name="meta" type="jsonb"/>
            <column name="created_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_at" type="timestamp"/>
        </createTable>

        <addForeignKeyConstraint baseTableSchemaName="analytics"
                                 baseTableName="analytics_relationship"
                                 baseColumnNames="from_entity_id"
                                 referencedTableSchemaName="analytics"
                                 referencedTableName="analytics_entity"
                                 referencedColumnNames="id"
                                 constraintName="fk_rel_from_entity"/>

        <addForeignKeyConstraint baseTableSchemaName="analytics"
                                 baseTableName="analytics_relationship"
                                 baseColumnNames="to_entity_id"
                                 referencedTableSchemaName="analytics"
                                 referencedTableName="analytics_entity"
                                 referencedColumnNames="id"
                                 constraintName="fk_rel_to_entity"/>

        <createIndex schemaName="analytics" tableName="analytics_relationship" indexName="idx_rel_from_to">
            <column name="from_entity_id"/>
            <column name="to_entity_id"/>
        </createIndex>
    </changeSet>
    <!-- Optional: helper: populate created_at default via DB function on insert -->
</databaseChangeLog>
