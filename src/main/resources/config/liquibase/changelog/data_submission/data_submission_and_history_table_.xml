<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <!-- ===================================================================
         1) Create sequence for submission serial numbers
         =================================================================== -->
    <changeSet id="20250815-01-create-submission-serial-seq" author="hamza">
        <createSequence sequenceName="submission_serial_seq" startValue="1"/>
    </changeSet>
    <!-- ===================================================================
         2) Create data_submission table
         =================================================================== -->
    <changeSet id="20250815-02-create-data-submission" author="hamza">
        <createTable tableName="data_submission">
            <!-- ULID primary key -->
            <column name="id" type="varchar(26)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- DB-generated serial number (default nextval from sequence) -->
            <column name="serial_number" type="bigint" defaultValueComputed="nextval('submission_serial_seq')"/>

            <!-- domain uid (short external id) -->
            <column name="uid" type="varchar(11)"/>

            <!-- form / version metadata -->
            <column name="form" type="varchar(255)"/>
            <column name="form_version" type="varchar(255)"/>
            <column name="version_number" type="integer"/>
            <column name="submission_version" type="integer" defaultValueNumeric="1"/>

            <!-- assignment/team/org unit -->
            <column name="team" type="varchar(64)"/>
            <column name="team_code" type="varchar(64)"/>
            <column name="org_unit" type="varchar(64)"/>
            <column name="org_unit_code" type="varchar(64)"/>
            <column name="org_unit_name" type="varchar(255)"/>
            <column name="activity" type="varchar(64)"/>
            <column name="assignment" type="varchar(64)"/>

            <!-- status and timestamps -->
            <column name="status" type="varchar(32)"/>
            <column name="start_entry_time" type="timestamp with time zone"/>
            <column name="finished_entry_time" type="timestamp with time zone"/>

            <!-- flexible JSON payload -->
            <column name="form_data" type="jsonb" defaultValueComputed="'{}'::jsonb"/>

            <!-- optimistic lock -->
            <column name="lock_version" type="bigint" defaultValueNumeric="0"/>

            <!-- auditing / soft-delete (common fields) -->
            <column name="created_by" type="varchar(100)"/>
            <column name="created_date" type="timestamp with time zone"/>
            <column name="last_modified_by" type="varchar(100)"/>
            <column name="last_modified_date" type="timestamp with time zone"/>
            <column name="translations" type="jsonb"/>
            <column name="deleted" type="boolean" defaultValueBoolean="false"/>
            <column name="deleted_at" type="timestamp with time zone"/>
        </createTable>

        <!-- Constraints and indexes -->
        <addNotNullConstraint tableName="data_submission" columnName="serial_number" columnDataType="bigint"/>

        <!-- Unique constraints -->
        <addUniqueConstraint tableName="data_submission" columnNames="serial_number"
                             constraintName="uk_data_submission_serial"/>
        <addUniqueConstraint tableName="data_submission" columnNames="uid" constraintName="uk_data_submission_uid"/>

        <!-- Standard indexes -->
        <createIndex indexName="idx_ds_form_assignment" tableName="data_submission">
            <column name="form"/>
            <column name="assignment"/>
        </createIndex>

        <createIndex indexName="idx_ds_orgunit" tableName="data_submission">
            <column name="org_unit"/>
        </createIndex>

        <createIndex indexName="idx_ds_serial_number" tableName="data_submission">
            <column name="serial_number"/>
        </createIndex>

        <!-- Partial index for active rows (deleted = false) for common queries -->
        <sql>
            CREATE INDEX IF NOT EXISTS idx_ds_active_form_assignment
                ON data_submission (form, assignment)
                WHERE (deleted = false);
        </sql>

        <!-- GIN index for jsonb form_data (use SQL since Liquibase createIndex lacks USING option) -->
        <sql>
            CREATE INDEX IF NOT EXISTS idx_ds_form_data_gin
                ON data_submission USING gin (form_data);
        </sql>
    </changeSet>

    <!-- ===================================================================
         3) Create data_submission_log table
         =================================================================== -->
    <changeSet id="20250815-03-create-submission-history" author="hamza">
        <createTable tableName="data_submission_log">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="submission_id" type="varchar(26)">
                <constraints nullable="false"/>
            </column>

            <column name="version_no" type="integer"/>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(100)"/>
            <column name="change_type" type="varchar(32)"/>
            <column name="form_data" type="jsonb"/>
            <column name="serial_number" type="bigint"/>
        </createTable>

        <!-- index for fast lookup by submission -->
        <createIndex tableName="data_submission_log" indexName="idx_sh_submission_id">
            <column name="submission_id"/>
        </createIndex>

        <!-- unique constraint so version numbers are unique per submission -->
        <addUniqueConstraint tableName="data_submission_log" columnNames="submission_id, version_no"
                             constraintName="uk_data_submission_log_submission_version"/>
    </changeSet>

    <!-- ===================================================================
         5) Optional housekeeping: set sequence value to max(serial_number) after import
         (used after bulk migration; you can run this manually or as a separate changeset)
         =================================================================== -->
