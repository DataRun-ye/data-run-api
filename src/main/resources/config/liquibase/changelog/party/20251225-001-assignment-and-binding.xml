<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="create-assignment-member-table" author="hamza-ye">
        <createTable tableName="assignment_member">
            <column name="id" type="bigserial">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_assignment_member"/>
            </column>
            <column name="assignment_id" type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="member_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="member_id" type="VARCHAR(26)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(255)"/>
            <column name="valid_from" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="valid_to" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="created_date" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="create-assignment-member-table-constraints" author="hamza-ye">
        <addForeignKeyConstraint baseTableName="assignment_member" baseColumnNames="assignment_id"
                                 constraintName="fk_assignment_member_assignment_id"
                                 referencedTableName="assignment" referencedColumnNames="id"/>
        <addUniqueConstraint tableName="assignment_member" constraintName="uc_assignment_member"
                             columnNames="assignment_id,member_type,member_id"/>

        <createIndex tableName="assignment_member" indexName="idx_assignment_member_assignment_id">
            <column name="assignment_id"/>
        </createIndex>
        <createIndex tableName="assignment_member" indexName="idx_assignment_member_member_type">
            <column name="member_type"/>
            <column name="member_id"/>
        </createIndex>
        <createIndex tableName="assignment_member" indexName="idx_assignment_member_member">
            <column name="member_id"/>
        </createIndex>
        <createIndex tableName="assignment_member" indexName="idx_assignment_member_valid_time">
            <column name="valid_from"/>
            <column name="valid_to"/>
        </createIndex>
    </changeSet>

