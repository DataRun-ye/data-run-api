<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1758899040182-1" author="Hamza">
        <createTable tableName="feature_flag">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_feature_flag"/>
            </column>
            <column name="uid" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(255)"/>
            <column name="environment" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="variations" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="rules" type="jsonb"/>
            <column name="rollout_strategy" type="jsonb"/>
            <column name="metadata" type="jsonb"/>
            <column name="version" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(255)"/>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_by" type="VARCHAR(255)"/>
            <column name="updated_at" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1758899040182-2" author="Hamza">
        <addUniqueConstraint columnNames="uid" constraintName="uc_feature_flag_uid" tableName="feature_flag"/>
    </changeSet>

</databaseChangeLog>
