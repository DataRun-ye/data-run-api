<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <changeSet id="1758757717738-38" author="Hamza">
        <createTable tableName="extraction_manifest">
            <column name="manifest_uid" type="VARCHAR(255)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_extraction_manifest"/>
            </column>
            <column name="submission_uid" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="template_version_uid" type="VARCHAR(64)"/>
            <column name="extraction_run_ts" type="DATETIME"/>
            <column name="manifest_json" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
