<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1758757717738-32" author="Hamza">
        <createSequence incrementBy="1" sequenceName="template_element_seq" startValue="1"/>
    </changeSet>
    <changeSet id="1758757717738-44" author="Hamza">
        <createTable tableName="template_element">
            <column name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_template_element"/>
            </column>
            <column name="uid" type="VARCHAR(11)">
                <constraints nullable="false"/>
            </column>
            <column name="element_kind" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="template_uid" type="VARCHAR(11)">
                <constraints nullable="false"/>
            </column>
            <column name="template_version_uid" type="VARCHAR(11)">
                <constraints nullable="false"/>
            </column>
            <column name="template_version_no" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="data_element_uid" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="value_type" type="VARCHAR(255)"/>
            <column name="aggregation_type" type="VARCHAR(32)"/>
            <column name="is_reference" type="BOOLEAN"/>
            <column name="is_category" type="BOOLEAN"/>
            <column name="option_set_uid" type="VARCHAR(11)"/>
            <column name="is_multi" type="BOOLEAN"/>
            <column name="is_measure" type="BOOLEAN"/>
            <column name="is_dimension" type="BOOLEAN"/>
            <column name="sort_order" type="INT"/>
            <column name="id_path" type="VARCHAR(3000)">
                <constraints nullable="false"/>
            </column>
            <column name="name_path" type="VARCHAR(3000)">
                <constraints nullable="false"/>
            </column>
            <column name="semantic_path" type="VARCHAR(3000)"/>
            <column name="ancestor_repeat_semantic_path" type="VARCHAR(3000)"/>
            <column name="repeat_uid" type="VARCHAR(64)"/>
            <column name="has_repeat_ancestor" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="ancestor_repeat_path" type="VARCHAR(3000)"/>
            <column defaultValueComputed="'{}'::jsonb" name="display_label" type="jsonb"/>
            <column name="definition_json" type="jsonb"/>
            <column name="is_natural_candidate" type="BOOLEAN"/>
            <column name="control_type" type="VARCHAR(64)"/>
            <column name="semantic_type" type="VARCHAR(64)"/>
            <column name="cardinality" type="VARCHAR(20)"/>
            <column name="schema_fingerprint" type="VARCHAR(64)"/>
            <column name="canonical_element_uid" type="VARCHAR(255)"/>
            <column name="category_id" type="VARCHAR(26)"/>
            <column defaultValueComputed="'[]'::jsonb" name="natural_key_candidates" type="jsonb"/>
            <column name="created_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1758757717738-52" author="Hamza">
        <addUniqueConstraint columnNames="uid" constraintName="uc_template_element_uid" tableName="template_element"/>
    </changeSet>
    <changeSet id="1758757717738-53" author="Hamza">
        <addUniqueConstraint columnNames="template_uid, template_version_uid, id_path"
                             constraintName="ux_template_element_tpl_ver_idpath" tableName="template_element"/>
    </changeSet>
    <changeSet id="1758757717738-70" author="Hamza">
        <createIndex indexName="idx_template_element_dataelement" tableName="template_element">
            <column name="data_element_uid"/>
        </createIndex>
    </changeSet>
    <changeSet id="1758757717738-71" author="Hamza">
        <createIndex indexName="idx_template_element_repeat_path" tableName="template_element">
            <column name="template_uid"/>
            <column name="ancestor_repeat_path"/>
        </createIndex>
    </changeSet>
    <changeSet id="1758757717738-72" author="Hamza">
        <createIndex indexName="idx_template_element_repeat_uid" tableName="template_element">
            <column name="repeat_uid"/>
        </createIndex>
    </changeSet>
    <changeSet id="1758757717738-73" author="Hamza">
        <createIndex indexName="idx_template_element_template_version" tableName="template_element">
            <column name="template_uid"/>
            <column name="template_version_uid"/>
        </createIndex>
    </changeSet>
    <changeSet id="1758757717738-74" author="Hamza">
        <createIndex indexName="idx_template_element_template_version_no" tableName="template_element">
            <column name="template_uid"/>
            <column name="template_version_no"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
