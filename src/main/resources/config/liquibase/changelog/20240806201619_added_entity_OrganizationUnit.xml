<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity OrganizationUnit.
    -->
    <changeSet id="20240806201619-1" author="jhipster">
        <createTable tableName="organization_unit">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uid" type="varchar(11)">
                <constraints nullable="true" unique="true" uniqueConstraintName="ux_organization_unit__uid" />
            </column>
            <column name="code" type="varchar(255)">
                <constraints nullable="true" unique="true" uniqueConstraintName="ux_organization_unit__code" />
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="ou_path" type="varchar(255)">
                <constraints nullable="false" />
            </column>
            <column name="parent" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="parent_code" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="level_id" type="bigint">
                <constraints nullable="false" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->
</databaseChangeLog>
