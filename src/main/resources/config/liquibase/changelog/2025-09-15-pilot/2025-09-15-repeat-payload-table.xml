<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="20250915-01-create-raw-repeat-payload" author="datarun">
        <createTable tableName="raw_repeat_payload">
            <column name="id" type="varchar(60)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="repeat_path" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="submission_uid" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="repeat_uid" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="payload_id" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="occurrence_index" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="payload_parent_id" type="varchar(32)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="20250915-01-create-raw-repeat-payload-indexes" author="datarun">
        <createIndex indexName="uq_raw_repeat_by_submission_occ" tableName="raw_repeat_payload">
            <column name="submission_uid"/>
            <column name="repeat_path"/>
            <column name="occurrence_index"/>
        </createIndex>
        <createIndex indexName="uq_raw_repeat_by_submission_payload_id" tableName="raw_repeat_payload">
            <column name="submission_uid"/>
            <column name="repeat_path"/>
            <column name="payload_id"/>
        </createIndex>
        <createIndex indexName="idx_raw_repeat_by_repeat_uid" tableName="raw_repeat_payload">
            <column name="repeat_uid"/>
        </createIndex>
        <createIndex indexName="idx_raw_repeat_by_path" tableName="raw_repeat_payload">
            <column name="repeat_path"/>
        </createIndex>
        <createIndex indexName="idx_raw_repeat_by_submission" tableName="raw_repeat_payload">
            <column name="submission_uid"/>
        </createIndex>
        <createIndex indexName="idx_raw_repeat_by_created_at" tableName="raw_repeat_payload">
            <column name="created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
