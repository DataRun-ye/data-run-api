<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">


    <!-- ============================
      000100: raw_submissions
      ============================ -->


    <!-- =========
      001 - raw_submissions
      ========= -->
    <changeSet id="001-create-raw_submissions" author="platform-team">
        <createTable tableName="raw_submissions">
            <column name="ingestion_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="received_at" type="timestamptz">
                <constraints nullable="false"/>
            </column>

            <column name="source_system" type="text"/>
            <column name="template_id" type="text"/>
            <column name="template_version" type="text"/>
            <column name="submission_id" type="text"/>
            <column name="user_id" type="text"/>
            <column name="org_unit" type="text"/>
            <column name="submission_json" type="jsonb">
                <constraints nullable="false"/>
            </column>

            <column name="outbox_event_id" type="uuid"/>
            <column name="created_at" type="timestamptz" defaultValueComputed="now()"/>
        </createTable>

        <createIndex indexName="idx_raw_submissions_template" tableName="raw_submissions">
            <column name="template_id"/>
            <column name="template_version"/>
        </createIndex>

        <createIndex indexName="idx_raw_submissions_received_at" tableName="raw_submissions">
            <column name="received_at"/>
        </createIndex>

        <createIndex indexName="idx_raw_submissions_submission" tableName="raw_submissions">
            <column name="submission_id"/>
        </createIndex>
    </changeSet>

    <!-- =========
         002 - bronze_nodes
         ========= -->
    <changeSet id="002-create-bronze_nodes" author="platform-team">
        <createTable tableName="bronze_nodes">
            <column name="bronze_id" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- provenance -->
            <column name="ingestion_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="submission_id" type="text"/>
            <column name="template_id" type="text"/>
            <column name="template_version" type="text"/>

            <!-- structural locator -->
            <column name="node_path" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="node_kind" type="text"/>
            <column name="value_type" type="text"/>
            <column name="role_suggestion" type="text"/>
            <column name="cardinality" type="text"/>

            <!-- repeat context -->
            <column name="repeat_instance_id" type="text"/>
            <column name="sequence_index" type="int"/>

            <!-- typed values -->
            <column name="value_string" type="text"/>
            <column name="value_num" type="numeric"/>
            <column name="value_bool" type="boolean"/>
            <column name="value_ts" type="timestamptz"/>
            <column name="value_array" type="jsonb"/>

            <!-- classification & profiling -->
            <column name="classifiers" type="jsonb"/>
            <column name="profiling" type="jsonb"/>

            <!-- parser & registry trace -->
            <column name="registry_version" type="text"/>
            <column name="parser_version" type="text"/>

            <column name="created_at" type="timestamptz" defaultValueComputed="now()"/>
        </createTable>

        <createIndex indexName="idx_bronze_nodes_template_path" tableName="bronze_nodes">
            <column name="template_id"/>
            <column name="template_version"/>
            <column name="node_path"/>
        </createIndex>

        <createIndex indexName="idx_bronze_nodes_ingestion" tableName="bronze_nodes">
            <column name="ingestion_id"/>
        </createIndex>
    </changeSet>

    <!-- =========
         003 - unique constraint / upsert helper (expression index)
         =========
         Liquibase does not universally support functional indexes via the <createIndex> tag,
         so we issue raw SQL to create the unique index required for idempotent upserts:
         uniqueness key: (ingestion_id, node_path, COALESCE(sequence_index, -1))
    -->
    <changeSet id="003-create-ux-bronze-ingestion-node" author="platform-team" runOnChange="false">
        <comment>Unique index used to make Bronze upserts idempotent</comment>
        <sql>
            CREATE UNIQUE INDEX IF NOT EXISTS ux_bronze_ingestion_node_seq
                ON bronze_nodes (ingestion_id, node_path, COALESCE(sequence_index, -1));
        </sql>
    </changeSet>

