    <!-- ============================
         000300: struct_registry
         ============================ -->
    <changeSet id="000300-create-struct-registry" author="platform-team">
        <createTable tableName="struct_registry">
            <column name="registry_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="template_id" type="text" />
            <column name="template_version" type="text" />
            <column name="registry_version" type="text" />
            <column name="author" type="text" />
            <column name="created_at" type="timestamptz" defaultValueComputed="now()"/>
            <column name="published_at" type="timestamptz"/>
            <column name="status" type="text" defaultValue="draft"/>
            <column name="spec" type="jsonb"/>
        </createTable>

        <createIndex indexName="idx_struct_reg_template" tableName="struct_registry">
            <column name="template_id"/>
            <column name="template_version"/>
            <column name="registry_version"/>
        </createIndex>
    </changeSet>

    <!-- ============================
         000400: mapping_registry
         ============================ -->
    <changeSet id="000400-create-mapping-registry" author="platform-team">
        <createTable tableName="mapping_registry">
            <column name="mapping_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="namespace" type="text" />
            <column name="mapping_version" type="text" />
            <column name="template_id" type="text" />
            <column name="template_version" type="text" />
            <column name="node_path" type="text" />
            <column name="dim_field_id" type="text" />
            <column name="role" type="text" />
            <column name="transform_sql" type="text"/>
            <column name="owner" type="text" />
            <column name="tests" type="jsonb" />
            <column name="created_by" type="text" />
            <column name="created_at" type="timestamptz" defaultValueComputed="now()"/>
            <column name="status" type="text" defaultValue="draft"/>
        </createTable>

        <createIndex indexName="idx_mapping_namespace" tableName="mapping_registry">
            <column name="namespace"/>
            <column name="mapping_version"/>
        </createIndex>
        <createIndex indexName="idx_mapping_lookup" tableName="mapping_registry">
            <column name="template_id"/>
            <column name="template_version"/>
            <column name="node_path"/>
        </createIndex>
    </changeSet>

    <!-- ============================
         000500: dim_field (SCD-ish)
         ============================ -->
    <changeSet id="000500-create-dim-field" author="platform-team">
        <createTable tableName="dim_field">
            <column name="surrogate_key" type="bigserial">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="dim_field_id" type="text"/>
            <column name="node_path" type="text"/>
            <column name="template_version" type="text"/>
            <column name="valid_from" type="timestamptz"/>
            <column name="valid_to" type="timestamptz"/>
            <column name="business_label" type="jsonb"/>
            <column name="metadata" type="jsonb"/>
            <column name="is_current" type="boolean" defaultValueBoolean="true"/>
        </createTable>

        <createIndex indexName="idx_dim_field_id" tableName="dim_field">
            <column name="dim_field_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
