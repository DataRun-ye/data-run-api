<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="20250915-02-create-projection-config" author="datarun">
        <createTable tableName="projection_config">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uid" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="text"/>
            <column name="target_type" type="varchar(32)"/>
            <column name="payload" type="jsonb"/>
            <column name="version" type="integer" defaultValueNumeric="1"/>
            <column name="created_by" type="varchar(64)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
