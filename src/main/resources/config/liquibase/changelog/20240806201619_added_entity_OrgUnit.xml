<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

<!--
        Added the entity OrgUnit.
    -->
    <changeSet id="1749225850985-23" author="Hamza">
        <createTable tableName="org_unit">
            <column name="id" type="VARCHAR(26)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_org_unit"/>
            </column>
            <column name="uid" type="VARCHAR(11)"/>
            <column name="code" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="path" type="VARCHAR(255)"/>
            <column name="level" type="INT"/>
            <column name="parent_id" type="VARCHAR(26)"/>
            <column name="translations" type="jsonb"/>
            <column name="created_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="DATETIME"/>
            <column name="last_modified_by" type="VARCHAR(50)"/>
            <column name="last_modified_date" type="DATETIME"/>
        </createTable>
    </changeSet>

    <changeSet id="1749225850985-24" author="Hamza">
        <createTable tableName="org_unit_group">
            <column name="id" type="VARCHAR(26)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_org_unit_group"/>
            </column>
            <column name="uid" type="VARCHAR(11)"/>
            <column name="code" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="symbol" type="VARCHAR(255)"/>
            <column name="color" type="VARCHAR(255)"/>
            <column name="inactive" type="BOOLEAN"/>
            <column name="translations" type="jsonb"/>
            <column name="created_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="DATETIME"/>
            <column name="last_modified_by" type="VARCHAR(50)"/>
            <column name="last_modified_date" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1749225850985-25" author="Hamza">
        <createTable tableName="org_unit_group_members">
            <column name="group_id" type="VARCHAR(26)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_org_unit_group_members"/>
            </column>
            <column name="org_unit_id" type="VARCHAR(26)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_org_unit_group_members"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1749225850985-26" author="Hamza">
        <createTable tableName="org_unit_groupset">
            <column name="id" type="VARCHAR(26)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_org_unit_groupset"/>
            </column>
            <column name="uid" type="VARCHAR(11)"/>
            <column name="code" type="VARCHAR(255)"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="translations" type="jsonb"/>
            <column name="created_by" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="DATETIME"/>
            <column name="last_modified_by" type="VARCHAR(50)"/>
            <column name="last_modified_date" type="DATETIME"/>
        </createTable>
    </changeSet>
    <changeSet id="1749225850985-27" author="Hamza">
        <createTable tableName="org_unit_groupset_org_unit_group">
            <column name="groupset_id" type="VARCHAR(26)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_org_unit_groupset_org_unit_group"/>
            </column>
            <column name="org_unit_group_id" type="VARCHAR(26)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_org_unit_groupset_org_unit_group"/>
            </column>
        </createTable>
    </changeSet>
    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->
</databaseChangeLog>
