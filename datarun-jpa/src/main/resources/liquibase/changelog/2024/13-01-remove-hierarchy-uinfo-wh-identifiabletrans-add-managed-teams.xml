    <changeSet id="1734120989068-1-create-team-managed-teams-table" author="Hamza (generated)">
        <createTable tableName="team_managed_teams">
            <column name="managed_team_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_team_managed_teams"/>
            </column>
            <column name="team_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_team_managed_teams"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1734120989068-2-add-team-enable-tofrom" author="Hamza (generated)">
        <addColumn tableName="team">
            <column name="enabled_from" type="DATETIME"/>
            <column name="enabled_to" type="DATETIME"/>
        </addColumn>
    </changeSet>
    <changeSet id="1734120989068-team-managed-teams-constraints" author="Hamza (generated)">
        <addForeignKeyConstraint baseColumnNames="managed_team_id" baseTableName="team_managed_teams"
                                 constraintName="fk_teamantea_on_managed_team" referencedColumnNames="id"
                                 referencedTableName="team"/>

        <addForeignKeyConstraint baseColumnNames="team_id" baseTableName="team_managed_teams"
                                 constraintName="fk_teamantea_on_team" referencedColumnNames="id"
                                 referencedTableName="team"/>
    </changeSet>
    <changeSet id="1734120989068-11-remove-team-tree-hierarchal-relation" author="Hamza (generated)">
        <dropForeignKeyConstraint baseTableName="team" constraintName="fk_team_on_parent"/>

        <dropColumn columnName="level" tableName="team"/>

        <dropColumn columnName="parent_id" tableName="team"/>

        <dropColumn columnName="path" tableName="team"/>
    </changeSet>
